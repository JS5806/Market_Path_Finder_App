# ===========================================
# Environment Variables (copy to .env and edit)
# ===========================================

# PostgreSQL (Docker)
DATABASE_URL=postgresql+asyncpg://mart_user:changeme@localhost:5432/mart_path_db
DATABASE_URL_SYNC=postgresql://mart_user:changeme@localhost:5432/mart_path_db

# JWT Auth
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MQTT Broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_ESL=mart/esl/update
MQTT_TOPIC_BEACON=mart/beacon/signal
MQTT_TOPIC_NFC=mart/nfc/tag

# Local LLM (4070 Ti PC)
LLM_API_BASE=http://192.168.0.100:8000/v1
LLM_MODEL_NAME=llama3-ko

# Server
APP_HOST=0.0.0.0
APP_PORT=8080
DEBUG=true
